apiVersion: helm.cattle.io/v1
kind: HelmChart
metadata:
  name: cilium
  namespace: kube-system
spec:
  repo: https://helm.cilium.io/
  chart: cilium
  version: "{{ cilium_version }}"
  targetNamespace: kube-system
  bootstrap: true
  valuesContent: |-
    kubeProxyReplacement: true
    k8sServiceHost: "{{ rke2_vip }}"
    k8sServicePort: 6443

    # eth0 = pod network, eth1 = storage (Ceph) — restrict Cilium to cluster NIC only
    devices: "eth0"

    routingMode: tunnel
    tunnelProtocol: vxlan

    bpf:
      masquerade: true

    ipam:
      mode: cluster-pool
      operator:
        clusterPoolIPv4PodCIDRList:
          - "{{ rke2_cluster_cidr }}"
        clusterPoolIPv4MaskSize: 24

    operator:
      replicas: 2
      tolerations:
        - operator: Exists

    # Disable L7 proxy — not using Cilium Gateway API or CiliumEnvoyConfig
    enable-l7-proxy: false

    hubble:
      enabled: true
      relay:
        enabled: true
      peerService:
        clusterDomain: {{ rke2_cluster_domain }}
