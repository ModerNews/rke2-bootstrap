apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: bootstrap-prod
  namespace: argocd
  finalizers:
    - resources-finalizer.argocd.argoproj.io
spec:
  project: default
  source:
    repoURL: {{ infra_helm_repo }}
    targetRevision: {{ infra_helm_revision }}
    path: .argocd/bootstrap/prod
  destination:
    server: "https://{{ rke2_api_fqdn }}:6443"
    namespace: argocd
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
      - ServerSideApply=true
